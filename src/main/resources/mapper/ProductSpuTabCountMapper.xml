<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.wenhao.product.spu.getcount.mapper.ProductSpuTabCountMapper">

    <!-- 统计销售中商品数量：status = 1（上架） -->
    <select id="countByStatusOnSale" resultType="java.lang.Long">
        SELECT COUNT(*) FROM product_spu WHERE status = 1 AND deleted = 0
    </select>

    <!-- 统计仓库中商品数量：status = 0（下架） -->
    <select id="countByStatusInWarehouse" resultType="java.lang.Long">
        SELECT COUNT(*) FROM product_spu WHERE status = 0 AND deleted = 0
    </select>

    <!-- 统计售空商品数量：stock = 0 -->
    <select id="countByStockEmpty" resultType="java.lang.Long">
        SELECT COUNT(*) FROM product_spu WHERE stock = 0 AND deleted = 0
    </select>

    <!-- 统计警戒库存商品数量：stock <= 10 且 status != -1（回收站） -->
    <select id="countByStockWarning" resultType="java.lang.Long">
        SELECT COUNT(*) FROM product_spu WHERE stock <= 10 AND stock > 0 AND status != -1 AND deleted = 0
    </select>

    <!-- 统计回收站商品数量：status = -1 -->
    <select id="countByStatusInRecycleBin" resultType="java.lang.Long">
        SELECT COUNT(*) FROM product_spu WHERE status = -1 AND deleted = 0
    </select>

</mapper>