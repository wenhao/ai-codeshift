<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.wenhao.product.property.listsimple.mapper.ProductPropertyListSimpleMapper">

    <resultMap id="ProductPropertyResultMap" type="com.github.wenhao.product.property.entity.po.ProductProperty">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectList" resultMap="ProductPropertyResultMap">
        SELECT id, name, remark, create_time, update_time, creator, updater, deleted
        FROM product_property
        WHERE deleted = 0
        ORDER BY id ASC
    </select>

</mapper>