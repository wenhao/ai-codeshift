<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.wenhao.product.spu.listallsimple.mapper.ProductSpuListAllSimpleMapper">

    <resultMap id="ProductSpuResultMap" type="com.github.wenhao.product.spu.entity.po.ProductSpu">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="keyword" property="keyword"/>
        <result column="introduction" property="introduction"/>
        <result column="description" property="description"/>
        <result column="category_id" property="categoryId"/>
        <result column="brand_id" property="brandId"/>
        <result column="pic_url" property="picUrl"/>
        <result column="slider_pic_urls" property="sliderPicUrls"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="spec_type" property="specType"/>
        <result column="price" property="price"/>
        <result column="market_price" property="marketPrice"/>
        <result column="cost_price" property="costPrice"/>
        <result column="stock" property="stock"/>
        <result column="delivery_types" property="deliveryTypes"/>
        <result column="delivery_template_id" property="deliveryTemplateId"/>
        <result column="give_integral" property="giveIntegral"/>
        <result column="sub_commission_type" property="subCommissionType"/>
        <result column="sales_count" property="salesCount"/>
        <result column="virtual_sales_count" property="virtualSalesCount"/>
        <result column="browse_count" property="browseCount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectListByStatus" resultMap="ProductSpuResultMap">
        SELECT *
        FROM product_spu
        WHERE deleted = 0
        AND status = #{status}
        ORDER BY sort ASC, id ASC
    </select>

</mapper>