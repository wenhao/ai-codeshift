<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.wenhao.product.spu.create.mapper.ProductSpuCreateMapper">

    <resultMap id="ProductCategoryResultMap" type="com.github.wenhao.product.category.entity.po.ProductCategory">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="name" property="name"/>
        <result column="pic_url" property="picUrl"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <resultMap id="ProductBrandResultMap" type="com.github.wenhao.product.brand.entity.po.ProductBrand">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="pic_url" property="picUrl"/>
        <result column="sort" property="sort"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <resultMap id="ProductPropertyResultMap" type="com.github.wenhao.product.property.entity.po.ProductProperty">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <resultMap id="ProductSkuResultMap" type="com.github.wenhao.product.spu.entity.po.ProductSku">
        <id column="id" property="id"/>
        <result column="spu_id" property="spuId"/>
        <result column="properties" property="properties" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="price" property="price"/>
        <result column="market_price" property="marketPrice"/>
        <result column="cost_price" property="costPrice"/>
        <result column="bar_code" property="barCode"/>
        <result column="pic_url" property="picUrl"/>
        <result column="stock" property="stock"/>
        <result column="weight" property="weight"/>
        <result column="volume" property="volume"/>
        <result column="first_brokerage_price" property="firstBrokeragePrice"/>
        <result column="second_brokerage_price" property="secondBrokeragePrice"/>
        <result column="sales_count" property="salesCount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="creator" property="creator"/>
        <result column="updater" property="updater"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectCategoryById" resultMap="ProductCategoryResultMap">
        SELECT * FROM product_category WHERE id = #{categoryId} AND deleted = 0
    </select>

    <select id="selectBrandById" resultMap="ProductBrandResultMap">
        SELECT * FROM product_brand WHERE id = #{brandId} AND deleted = 0
    </select>

    <select id="selectPropertyByIds" resultMap="ProductPropertyResultMap">
        SELECT * FROM product_property WHERE id IN
        <foreach collection="propertyIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND deleted = 0
    </select>

    <select id="selectSkuBySpuId" resultMap="ProductSkuResultMap">
        SELECT * FROM product_sku WHERE spu_id = #{spuId} AND deleted = 0
    </select>

    <insert id="batchInsertSku" parameterType="java.util.List">
        INSERT INTO product_sku (spu_id, properties, price, market_price, cost_price, bar_code, pic_url, stock,
                                  weight, volume, first_brokerage_price, second_brokerage_price, sales_count,
                                  create_time, update_time, creator, updater, deleted)
        VALUES
        <foreach collection="skuList" item="sku" separator=",">
            (#{sku.spuId}, #{sku.properties}, #{sku.price}, #{sku.marketPrice}, #{sku.costPrice},
             #{sku.barCode}, #{sku.picUrl}, #{sku.stock}, #{sku.weight}, #{sku.volume},
             #{sku.firstBrokeragePrice}, #{sku.secondBrokeragePrice}, #{sku.salesCount},
             NOW(), NOW(), #{sku.creator}, #{sku.updater}, 0)
        </foreach>
    </insert>

</mapper>